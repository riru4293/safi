@startuml
actor Client
participant ValidatorFactory
participant Validator
participant ConstraintValidator
participant MessageInterpolator
participant RequestContext
participant ResourceBundle
participant ConstraintViolation

Client -> ValidatorFactory : getValidator()
ValidatorFactory --> Client : Validator

Client -> Validator : validate(bean)

Validator -> ConstraintValidator : isValid(value, context)
ConstraintValidator --> Validator : false

Validator -> MessageInterpolator : interpolate(messageTemplate, context)

MessageInterpolator --> RequestContext : getLocale
RequestContext --> MessageInterpolator : locale

MessageInterpolator -> ResourceBundle : lookup(message key, locale)
ResourceBundle --> MessageInterpolator : localized message

MessageInterpolator --> Validator : interpolated message

Validator -> ConstraintViolation : create(message)
ConstraintViolation --> Client : violations

@enduml

