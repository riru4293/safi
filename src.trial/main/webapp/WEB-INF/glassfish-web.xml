<glassfish-web-app>
    <context-root>safi</context-root>
    <class-loader delegate="true"/>
    <jsp-config>
        <property name="keepgenerated" value="true"/>
    </jsp-config>
    <session-config>
        <session-manager>
            <session-properties>
                <property name="disableSession" value="true"/>
                <property name="enableCookies" value="false"/>
                <property name="enableURLRewriting" value="false"/>
            </session-properties>
        </session-manager>
    </session-config>
</glassfish-web-app>
